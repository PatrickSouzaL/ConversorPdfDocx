# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# Logs
*.log

# Artefatos de conversão (arquivos gerados)
docx/*.docx

# Arquivos de origem (documentos internos) — não versionar
pdf/*.pdf

# Dados de idioma do Tesseract (binários grandes, específicos da máquina).
# Fallback local usado quando o idioma não está instalado no sistema.
.tessdata/

# Poppler portátil (binário do pdf2image; grande, específico da máquina).
.poppler/

# Ferramentas de agentes / IDE
.agents/
.claude/

# SO / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/

# Manter as pastas de trabalho no repositório
!docx/.gitkeep
!pdf/.gitkeep
